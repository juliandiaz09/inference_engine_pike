perfil_felino(guepardo,               mammalia, carnivora, felidae, acinonyx,  savanna,             solid_spots,     extreme_speed, africa,        diurnal)
perfil_felino(puma,                   mammalia, carnivora, felidae, puma,      mountain,            plain_coat,      purr,          america,       crepuscular)
perfil_felino(leopardo_de_las_nieves, mammalia, carnivora, felidae, panthera,  alpine_tundra,       rosette_spots,   purr,          central_asia,  crepuscular)
