# ============================================================
# Base de hechos — Felinos grandes (Familia Felidae)
# Sistema experto de clasificación taxonómica
# ============================================================
# Formato:
# perfil_felino(animal, clase, orden, familia, genero,
#               habitat, patron_pelaje, capacidad, region, actividad)

perfil_felino(jaguar,                 mammalia, carnivora, felidae, panthera,  tropical_rainforest, rosette_spots,   swim,          america,       nocturnal)
