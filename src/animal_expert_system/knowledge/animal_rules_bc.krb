# Backward chaining rules for bird identification.
# All fact calls on a single line for Pyke 1.1.1 compatibility.
#
# ESTRUCTURA DE PRUEBA:
#
# NIVEL EXACTO (5/5):
#   taxonomy($bird_id, $order, $family)
#     -> is_<orden>_exact($bird_id, $order, $family)
#          -> bird_profile + 5 characteristic facts
#
# NIVEL PARCIAL 4/5:
#   taxonomy_partial($bird_id, $order, $family, $score)
#     -> is_<orden>_partial($bird_id, $order, $family)
#          -> bird_profile + 4 characteristic facts (1 libre)
#          -> assert score_4
#
# NIVEL PARCIAL 3/5:
#   taxonomy_partial($bird_id, $order, $family, $score)
#     -> is_partial_trio($bird_id, $order, $family)
#          -> bird_profile + habitat + diet + morphology

# ================================================================
# META EXACTA: taxonomy
# ================================================================

taxonomy_accipitriformes
    use taxonomy($bird_id, $order, $family)
    when
        is_accipitriforme($bird_id, $order, $family)

taxonomy_strigiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_strigiforme($bird_id, $order, $family)

taxonomy_passeriformes
    use taxonomy($bird_id, $order, $family)
    when
        is_passeriforme($bird_id, $order, $family)

taxonomy_psittaciformes
    use taxonomy($bird_id, $order, $family)
    when
        is_psittaciforme($bird_id, $order, $family)

taxonomy_columbiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_columbiforme($bird_id, $order, $family)

taxonomy_charadriiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_charadriforme($bird_id, $order, $family)

taxonomy_pelecaniformes
    use taxonomy($bird_id, $order, $family)
    when
        is_pelecaniforme($bird_id, $order, $family)

taxonomy_gruiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_gruiforme($bird_id, $order, $family)

taxonomy_coraciiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_coraciiforme($bird_id, $order, $family)

taxonomy_anseriformes
    use taxonomy($bird_id, $order, $family)
    when
        is_anseriforme($bird_id, $order, $family)

taxonomy_phoenicopteriformes
    use taxonomy($bird_id, $order, $family)
    when
        is_phoenicopteriforme($bird_id, $order, $family)

taxonomy_cathartiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_cathartiiforme($bird_id, $order, $family)

taxonomy_piciformes
    use taxonomy($bird_id, $order, $family)
    when
        is_piciforme($bird_id, $order, $family)

taxonomy_ciconiiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_ciconiiforme($bird_id, $order, $family)

taxonomy_suliformes
    use taxonomy($bird_id, $order, $family)
    when
        is_suliforme($bird_id, $order, $family)

taxonomy_struthioniformes
    use taxonomy($bird_id, $order, $family)
    when
        is_struthioniforme($bird_id, $order, $family)

taxonomy_podicipediformes
    use taxonomy($bird_id, $order, $family)
    when
        is_podicipediforme($bird_id, $order, $family)

taxonomy_apodiformes
    use taxonomy($bird_id, $order, $family)
    when
        is_apodiforme($bird_id, $order, $family)

# ================================================================
# META PARCIAL: taxonomy_partial
# Pyke intenta primero 4/5 para cada orden, luego el trio 3/5.
# ================================================================

partial_accipitriformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_accipitriforme_partial($bird_id, $order, $family)

partial_strigiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_strigiforme_partial($bird_id, $order, $family)

partial_passeriformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_passeriforme_partial($bird_id, $order, $family)

partial_psittaciformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_psittaciforme_partial($bird_id, $order, $family)

partial_columbiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_columbiforme_partial($bird_id, $order, $family)

partial_charadriiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_charadriforme_partial($bird_id, $order, $family)

partial_pelecaniformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_pelecaniforme_partial($bird_id, $order, $family)

partial_gruiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_gruiforme_partial($bird_id, $order, $family)

partial_coraciiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_coraciiforme_partial($bird_id, $order, $family)

partial_anseriformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_anseriforme_partial($bird_id, $order, $family)

partial_phoenicopteriformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_phoenicopteriforme_partial($bird_id, $order, $family)

partial_cathartiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_cathartiiforme_partial($bird_id, $order, $family)

partial_piciformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_piciforme_partial($bird_id, $order, $family)

partial_ciconiiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_ciconiiforme_partial($bird_id, $order, $family)

partial_suliformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_suliforme_partial($bird_id, $order, $family)

partial_struthioniformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_struthioniforme_partial($bird_id, $order, $family)

partial_podicipediformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_podicipediforme_partial($bird_id, $order, $family)

partial_apodiformes_4
    use taxonomy_partial($bird_id, $order, $family, score_4)
    when
        is_apodiforme_partial($bird_id, $order, $family)

partial_trio_3
    use taxonomy_partial($bird_id, $order, $family, score_3)
    when
        is_partial_trio($bird_id, $order, $family)

# ================================================================
# SUB-OBJETIVOS EXACTOS (5/5)
# ================================================================

is_accipitriforme
    use is_accipitriforme($bird_id, $order, $family)
    when
        animals.bird_profile($bird_id, $_, $_, $order, $family, $habitat, $diet, $morphology, $size, $activity)
        check $order =~ Accipitriformes
        animals.characteristic(habitat, $habitat)
        animals.characteristic(diet, $diet)
        animals.characteristic(morphology, $morphology)
        animals.characteristic(size, $size)
        animals.characteristic(activity, $activity)

