# ================================================================
# SUB-OBJETIVO TRIO 3/5: habitat + diet + morphology
# ================================================================

is_partial_trio
    use is_partial_trio($bird_id, $order, $family)
    when
        animals.bird_profile($bird_id, $_, $_, $order, $family, $habitat, $diet, $morphology, $_, $_)
        animals.characteristic(habitat, $habitat)
        animals.characteristic(diet, $diet)
        animals.characteristic(morphology, $morphology)
